{
  "name": "dqi-audit-analytics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "concurrently -n api,web -c cyan,magenta \"npm:dev -w @dqi/api\" \"npm:dev -w @dqi/web\"",
    "build": "npm run build -w @dqi/contracts && npm run build -w @dqi/analytics-core && npm run build -w @dqi/api && npm run build -w @dqi/web",
    "test": "vitest run",
    "typecheck": "tsc -b --pretty false",
    "lint": "eslint .",
    "check": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.30",
    "concurrently": "^9.1.2",
    "eslint": "^9.28.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vitest": "^3.2.2"
  },
  "engines": { "node": ">=20" }
}
